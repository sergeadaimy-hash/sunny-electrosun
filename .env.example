# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Owner notifications
OWNER_WHATSAPP=
OWNER_EMAIL=

# Specialist click-to-chat link appended to escalation holding replies.
# Phone number in international format, digits only, no plus sign.
# When set, customers who hit a HOT lead or silent_query escalation get
# a wa.me link to reach this number directly. Leave empty to disable.
SPECIALIST_DIRECT_LINK=

# Email fallback (SMTP)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Server
PORT=3000

# Dashboard API
API_KEY=

# Cost guardrail (USD per day)
DAILY_LLM_BUDGET_USD=5

# Set to "false" on cloud PaaS (Railway, Fly.io, etc.) where filesystem is
# ephemeral. Disables logs/sunny.log file writes and the daily DB snapshot,
# leaving only stdout/stderr (which the platform captures). Default is to
# write to file (suitable for laptop and Mac Mini).
LOG_TO_FILE=true

# Path to the SQLite database file. Defaults to db/sunny.db inside the repo
# (suitable for laptop and Mac Mini). On cloud PaaS, point this at the
# mounted persistent volume, e.g. DB_PATH=/data/sunny.db on Railway.
DB_PATH=

# Directory for downloaded customer media (WhatsApp images). Defaults to
# <DB_PATH dirname>/media so it sits next to the SQLite file on the same
# volume. Override only if you want media stored separately.
MEDIA_DIR=
